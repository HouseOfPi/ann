nst sy = BIAS_POS.y + (dy/dist) * 28;\n        const ex = CX - (dx/dist) * NEURON_R;\n        const ey = CY - (dy/dist) * NEURON_R;\n        const segLen = Math.sqrt((ex-sx)**2 + (ey-sy)**2);\n        const delay = drawStart + N_INPUTS * 0.1;\n        const progress = clamp(animate({ from:0, to:1, start:delay, end:delay+drawDur, ease:Easing.easeInOutCubic })(t), 0, 1);\n        if (progress === 0) return null;\n        // Animate a solid line revealing the dashed pattern by clipping via a second stroke\n        const visibleLen = segLen * progress;\n        const angle = Math.atan2(ey - sy, ex - sx);\n        const cex = sx + Math.cos(angle) * visibleLen;\n        const cey = sy + Math.sin(angle) * visibleLen;\n        return (\n          <line x1={sx} y1={sy} x2={cex} y2={cey}\n            stroke={COLORS.dim} strokeWidth={1.5} strokeLinecap=\"round\"\n            strokeDasharray=\"4 6\"\n            opacity={0.7}\n          />\n        );\n      })", "source_file": "/Users/mosesmathew/Desktop/Personal/ANN_presentation/code_yt_gemini/ann/assets/ann animation/scenes.jsx", "source_location": "L370"}, {"caller_nid": "scenes_outputline", "callee": "useTime", "source_file": "/Users/mosesmathew/Desktop/Personal/ANN_presentation/code_yt_gemini/ann/assets/ann animation/scenes.jsx", "source_location": "L401"}, {"caller_nid": "scenes_outputline", "callee": "clamp", "source_file": "/Users/mosesmathew/Desktop/Personal/ANN_presentation/code_yt_gemini/ann/assets/ann animation/scenes.jsx", "source_location": "L404"}, {"caller_nid": "scenes_outputline", "callee": "animate({\n    from: 0, to: 1, start: drawStart, end: drawStart + 1.0, ease: Easing.easeInOutCubic,\n  })", "source_file": "/Users/mosesmathew/Desktop/Personal/ANN_presentation/code_yt_gemini/ann/assets/ann animation/scenes.jsx", "source_location": "L404"}, {"caller_nid": "scenes_outputline", "callee": "animate", "source_file": "/Users/mosesmathew/Desktop/Personal/ANN_presentation/code_yt_gemini/ann/assets/ann animation/s